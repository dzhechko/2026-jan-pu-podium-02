# ReviewHub Production Environment
# Copy to .env.production and fill in real values

# Database (internal Docker network)
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password

# Auth (generate: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_64_char_hex
JWT_REFRESH_SECRET=CHANGE_ME_another_64_char_hex

# Encryption (generate: openssl rand -hex 32)
ENCRYPTION_KEY=CHANGE_ME_64_char_hex_for_aes256

# SMSC.ru SMS Provider
SMSC_LOGIN=your_smsc_login
SMSC_PASSWORD=your_smsc_password
SMSC_SENDER=ReviewHub

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-api03-...

# URLs (your actual domains)
APP_URL=https://admin.reviewhub.ru
PWA_URL=https://review.reviewhub.ru

# General
NODE_ENV=production
PORT=3000
