# Database
DATABASE_URL=postgresql://reviewhub:reviewhub@localhost:5432/reviewhub

# Redis
REDIS_URL=redis://localhost:6379

# Auth (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-random-64-char-string-for-production
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string

# SMSC.ru SMS Provider
SMSC_LOGIN=your_login
SMSC_PASSWORD=your_password
SMSC_SENDER=ReviewHub

# Anthropic Claude API (for sentiment analysis)
ANTHROPIC_API_KEY=sk-ant-...

# Encryption (generate with: openssl rand -hex 16)
ENCRYPTION_KEY=change-me-to-random-32-plus-char-string

# App URLs
APP_URL=http://localhost:5173
PWA_URL=http://localhost:5174

# General
NODE_ENV=development
PORT=3000
